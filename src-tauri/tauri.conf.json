{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CanIReach",
  "version": "1.0.0-rc.3",
  "identifier": "com.ebrahim.canireach",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CanIReach",
        "width": 1200,
        "height": 800
      },
      {
        "label": "compact",
        "title": "CanIReach Mini-Dashboard",
        "width": 360,
        "height": 450,
        "resizable": false,
        "fullscreen": false,
        "alwaysOnTop": true,
        "visible": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW51c2VkX3B1YmxpY19rZXlfdGVzdF9iYXNlNjRfZGF0YQ==",
      "endpoints": [
        "https://releases.canireach.com/updates/{{target}}-{{arch}}.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15"
    }
  }
}
